#ifndef KNR_STYLE /* STANDARD C */
static void
	__THREAD_WRAPPER__(void *ARG_PTR)
#else /* K&R */
static
	__THREAD_WRAPPER__(ARG_PTR)
	char	*ARG_PTR;
#endif /* !KNR_STYLE */
{
	struct S_THREAD_MANAGER	*THREAD_MANAGER;
	register unsigned int	WAITERS;

	THREAD_MANAGER = (struct S_THREAD_MANAGER *)ARG_PTR;
	THREAD_MANAGER->RETURN = THREAD_MANAGER->FUNCTION(THREAD_MANAGER->ARG);
	MUTEX_LOCK(THREAD_MANAGER->MUTEX_OPEN);
	THREAD_MANAGER->OPEN = 0;
	MUTEX_UNLOCK(THREAD_MANAGER->MUTEX_OPEN);
	MUTEX_LOCK(THREAD_MANAGER->MUTEX_JOIN);
	WAITERS = THREAD_MANAGER->JOINS;
	THREAD_MANAGER->JOINS = 0;
	MUTEX_UNLOCK(THREAD_MANAGER->MUTEX_JOIN);

	while (WAITERS--)
		MUTEX_UNLOCK(THREAD_MANAGER->MUTEX);

	MUTEX_DESTROY(&(THREAD_MANAGER->MUTEX_JOIN));
	MUTEX_DESTROY(&(THREAD_MANAGER->MUTEX_OPEN));
	MUTEX_DESTROY(&(THREAD_MANAGER->MUTEX));
	FREE(THREAD_MANAGER);
}

#ifndef KNR_STYLE /* STANDARD C */
#define FUNCTION_HEADER__THREAD_CREATE \
	T_THREAD \
		THREAD_CREATE(PTR (*FUNCTION)(PTR), PTR ARG)
#else /* K&R */
#define FUNCTION_HEADER__THREAD_CREATE \
	T_THREAD \
		THREAD_CREATE(FUNCTION, ARG)\
		PTR	(*FUNCTION)();\
		PTR	ARG;
#endif /* !KNR_STYLE */

#define LOCALFUNCTION__THREAD_CREATE \
	FUNCTION_HEADER__THREAD_CREATE \
	{\
		struct S_THREAD_MANAGER	*RESULT;\
		Task_Params				TASK_PARAMS;\
		\
		RESULT = ALLOC(sizeof(struct S_THREAD_MANAGER));\
		\
		if (!RESULT)\
			return ((T_THREAD)0);\
		\
		RESULT->ARG = ARG;\
		RESULT->FUNCTION = FUNCTION;\
		RESULT->OPEN = 0;\
		RESULT->JOINS = 0;\
		MUTEX_CREATE(&(RESULT->MUTEX));\
		MUTEX_CREATE(&(RESULT->MUTEX_JOIN));\
		MUTEX_CREATE(&(RESULT->MUTEX_OPEN));\
		MUTEX_LOCK(RESULT->MUTEX);\
		Task_Params_init(&TASK_PARAMS);\
		TASK_PARAMS.arg0 = (UArg)RESULT;\
		TASK_PARAMS.stackSize = 1024;\
		RESULT->THREAD = Task_create(\
			(Task_FuncPtr)__THREAD_WRAPPER__, &TASK_PARAMS, (Error_Block *)0\
		);\
		\
		if (!RESULT->THREAD)\
		{\
			MUTEX_DESTROY(&(RESULT->MUTEX_JOIN));\
			MUTEX_DESTROY(&(RESULT->MUTEX_OPEN));\
			MUTEX_DESTROY(&(RESULT->MUTEX));\
			FREE(RESULT);\
			return ((T_THREAD)0);\
		}\
		\
		RESULT->OPEN = 1;\
		return (RESULT);\
	}

